name: strawberries-os
description: Просто. Розово. Охуенно.
base-image: ghcr.io/ublue-os/bazzite-nvidia
image-version: latest

modules:
  - type: rpm-ostree
    install:
      - fastfetch
      - pipewire-alsa
      - gnome-shell-extension-dash-to-dock

  - type: flatpak
    remote: flathub
    install:
      - com.valvesoftware.Steam
      - net.davidotek.pupgui2 # Proton
      - org.blender.Blender # Для кроссовок

  - type: script
    scripts:
      - |
        echo "🍓 Настройка Strawberries OS..."
        # Скрипт для Gemini и Розовой темы
        mkdir -p /usr/bin/
        echo 'echo "🍓 Gemini AI готов! Нажми Enter для магии."' > /usr/bin/berry-ai
        chmod +x /usr/bin/berry-ai
